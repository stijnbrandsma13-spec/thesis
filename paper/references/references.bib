@article{YinCherchi2024,
  author    = {Yin, Hao and Cherchi, Elisabetta},
  title     = {Willingness to pay for automated taxis: a stated choice experiment to measure the impact of in-vehicle features and customer reviews},
  journal   = {Transportation},
  year      = {2024},
  volume    = {51},
  number    = {1},
  pages     = {51--72},
  doi       = {10.1007/s11116-022-10319-3},
  url       = {https://doi.org/10.1007/s11116-022-10319-3},
  issn      = {1572-9435},
  abstract  = {This study aims to contribute to the limited empirical evidence on Automated Taxis (ATs) by analysing the in-vehicle features that ATs ought to have to satisfy taxi passengers requests that in a Normal Taxi (NT) are dealt with a direct communication between the passenger and the driver. Based on the results of focus groups and several pilots, two in-vehicle features are tested: change of destination and chat with an operator during the trip. The paper also contributes to the body of literature on the impact of social influence on the adoption of innovation by testing the impact of consumer reviews other than the typical measure of adoption and injunctive norms. A Stated Choice (SC) experiment was built putting particular effort in the definition and presentation of the new attributes tested. The study was applied in China among current users of NTs (i.e. with the driver). Hybrid choice models were estimated and a resampling technique was used to test the model sensitivity to the sample gathered. Results show that on average, Chinese taxi users are willing to pay 0.35 Euros to have the option to ‘change the destination’ and 0.78 Euros to be able to ‘chat with an operator’ inside the AT. Among the social influence attributes, the reviews from previous customers confirmed to be the most effective measure, users are willing to pay 1.58 Euros more to use a taxi that got good reviews for long trips (≥ 30 min) and 0.57 Euros for shorter trips. The WTP estimated are all significant at more than 95% and have narrow confidence intervals.}
}

@article{ZhouWangYangGanLiuZi2025,
author = {Yiwei Zhou  and Ziyuan Wang  and Shuo Yang  and Hongcheng Gan  and Dan Liu  and Haibo Zi },
title = {Investigating the Bike Sharing Brand Selection of Young People Using a Mixed Logit Model: A Case Study of Shanghai},
journal = {Journal of Transportation Engineering, Part A: Systems},
volume = {151},
number = {12},
pages = {04025095},
year = {2025},
doi = {10.1061/JTEPBS.TEENG-8443},

URL = {https://ascelibrary.org/doi/abs/10.1061/JTEPBS.TEENG-8443},
eprint = {https://ascelibrary.org/doi/pdf/10.1061/JTEPBS.TEENG-8443}
,
    abstract = { With the rapid development of information technology, bike sharing has emerged as an important travel mode, and many studies have been published on bike sharing in recent years. Unlike past studies, this paper focuses on brand selection in free-floating bike sharing among specific young people, considering heterogeneous preferences to reveal hidden factors in users’ brand selection. A mixed logit model with correlated random coefficients is established based on survey data in Shanghai, China. The results indicate that alternative specific variables, such as deposit and charge level, have a strong negative correlation with brand choice, while the fleet size and riding experience reveal strong positive correlations, which implies that young people tend to choose a brand with low deposit, low charge, larger fleet size, and good riding experience. In addition, individual characteristics variables, such as gender, income, and education level, also show significantly positive impacts on brand selection. Policy implications are derived to place more bikes in zones with higher income and education levels. At the same time, bike sharing companies should be very cautious when raising the deposit or charge level while expanding fleet size and enhancing riding comfort to attract more users. These policy suggestions could help facilitate bike sharing trips and provide better mobility services. }
}

@techreport{HoudeMyers2019,
 title = "Heterogeneous (Mis-) Perceptions of Energy Costs:  Implications for Measurement and Policy Design",
 author = "Houde, Sébastien and Myers, Erica",
 institution = "National Bureau of Economic Research",
 type = "Working Paper",
 series = "Working Paper Series",
 number = "25722",
 year = "2019",
 month = "April",
 doi = {10.3386/w25722},
 URL = "http://www.nber.org/papers/w25722",
 abstract = {Quantifying heterogeneity in consumers’ misperceptions of product costs is crucial for policy design. We illustrate this point in the context of energy-using durables, where a long-standing policy debate continues on whether taxes or standards are superior for regulating externalities. We derive formulae to quantify welfare effects for each instrument, accounting for misperceptions. Standards have a notable advantage over taxes. They reduce the variance of the misperceived attribute in the choice set, which reduces allocative inefficiencies. In the U.S. appliance market, standards dominate taxes across scenarios, and correctly characterizing misperception heterogeneity is less important for setting optimal standards than for taxes.},
}

